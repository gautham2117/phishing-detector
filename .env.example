# Copy this file to .env and fill in your values
# NEVER commit the .env file itself

FLASK_SECRET_KEY=change-this-to-a-random-string-in-production
FLASK_ENV=development
FLASK_DEBUG=True

FASTAPI_HOST=127.0.0.1
FASTAPI_PORT=8001

DATABASE_URL=sqlite:///database/phishing_detector.db

# Admin credentials (change before any deployment)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Redis (for task queue concept - not required for local dev)
REDIS_URL=redis://localhost:6379/0

# Optional: VirusTotal API key for hash lookups (free tier available)
VIRUSTOTAL_API_KEY=

# Optional: IPInfo token for geolocation
IPINFO_TOKEN=

SCAN_AUTHORIZED=1

